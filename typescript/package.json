{
  "name": "deepagents-chromafs",
  "version": "0.1.0",
  "description": "ChromaDB virtual filesystem backend for deepagents (JS/TS) — instant session creation via the ChromaFs algorithm.",
  "keywords": [
    "agents",
    "ai",
    "llm",
    "chromadb",
    "filesystem",
    "rag",
    "deepagents",
    "langchain"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./redis-cache": {
      "import": {
        "types": "./dist/redis-cache.d.ts",
        "default": "./dist/redis-cache.js"
      },
      "require": {
        "types": "./dist/redis-cache.d.cts",
        "default": "./dist/redis-cache.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "chromadb": ">=1.9.0",
    "deepagents": ">=1.0.0"
  },
  "dependencies": {
    "micromatch": "^4.0.8"
  },
  "optionalDependencies": {
    "ioredis": ">=5.0.0"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "chromadb": "^1.10.0",
    "deepagents": "^1.10.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ki3nd/deepagents-chromafs.git",
    "directory": "typescript"
  },
  "homepage": "https://github.com/ki3nd/deepagents-chromafs#readme"
}
