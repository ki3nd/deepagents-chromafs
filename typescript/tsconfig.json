{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./deepagents_chromafs",
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["deepagents_chromafs/**/*"],
  "exclude": ["node_modules", "dist", "tests"]
}
